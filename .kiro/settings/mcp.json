{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\mihai\\Documents",
        "C:\\Users\\mihai\\Desktop"
      ],
      "autoApprove": [
        "edit_file"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      },
      "disabled": true
    },
    "brave-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "YOUR_BRAVE_API_KEY_HERE"
      },
      "disabled": true
    },
    "docker": {
      "command": "npx",
      "args": [
        "-y",
        "@thelord/mcp-server-docker-npx"
      ],
      "disabled": true
    },
    "postman": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-postman"
      ],
      "disabled": true
    },
    "puppeteer": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "disabled": true
    },
    "windows-automation": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-windows-automation"
      ],
      "disabled": true
    },
    "MCP_DOCKER": {
      "command": "docker",
      "args": [
        "mcp",
        "gateway",
        "run"
      ],
      "env": {
        "LOCALAPPDATA": "C:\\Users\\mihai\\AppData\\Local",
        "ProgramData": "C:\\ProgramData",
        "ProgramFiles": "C:\\Program Files"
      },
      "disabledTools": [
        "browser_click",
        "browser_close",
        "browser_console_messages",
        "browser_drag",
        "browser_evaluate",
        "browser_file_upload",
        "browser_fill_form",
        "browser_handle_dialog",
        "browser_hover",
        "browser_navigate",
        "browser_navigate_back",
        "browser_network_requests",
        "browser_press_key",
        "browser_resize",
        "browser_run_code",
        "browser_select_option",
        "browser_snapshot",
        "browser_tabs",
        "browser_take_screenshot",
        "browser_type",
        "browser_wait_for",
        "code-mode",
        "get-library-docs",
        "mcp-add",
        "mcp-config-set",
        "mcp-exec",
        "mcp-find",
        "mcp-remove",
        "resolve-library-id",
        "search_astro_docs"
      ]
    }
  }
}