###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me-to-a-random-32-char-string
APP_DEBUG=1
###< symfony/framework-bundle ###

###> symfony/mailer ###
# MailHog (local dev) — matches the mailhog Docker service
MAILER_DSN=smtp://mailhog:1025
###< symfony/mailer ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> app/pgp ###
# Passphrase protecting the server's PGP private key.
# The key itself lives at config/pgp/private.key (generated by scripts/docker-setup-pgp.sh).
PGP_PRIVATE_KEY_PASSPHRASE=your-secure-passphrase
###< app/pgp ###
