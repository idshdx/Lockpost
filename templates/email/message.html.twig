<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Email with PGP</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1.6;
            margin: 0;
            padding: 0;
            background-color: #f8f9fa;
            color: #212529;
        }

        h1 {
            text-align: center;
            color: #343a40;
            margin: 20px 0;
        }

        .container {
            max-width: 800px;
            margin: 20px auto;
            background-color: #ffffff;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            padding: 20px;
        }

        .section-title {
            color: #495057;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .pgp-content {
            font-family: 'Courier New', monospace, monospace;
            background-color: #f1f3f5;
            border: 1px solid #ced4da;
            padding: 15px;
            border-radius: 5px;
            margin-bottom: 10px;
            overflow: auto;
        }

        .button {
            background-color: #0069d9;
            border: none;
            color: white;
            padding: 10px 20px;
            font-size: 14px;
            font-weight: bold;
            text-decoration: none;
            border-radius: 4px;
            cursor: pointer;
            display: inline-block;
            text-align: center;
            transition: all 0.3s ease;
            width: 150px;
        }

        .button:hover {
            background-color: #0056b3;
            transform: scale(1.05);
        }

        .divider {
            border-top: 2px dashed #dee2e6;
            margin: 30px 0;
        }

        .collapsible {
            background-color: #f8f9fa;
            color: #007bff;
            border: 1px solid #ced4da;
            padding: 10px;
            font-size: 16px;
            font-weight: bold;
            text-align: left;
            border-radius: 4px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            transition: background-color 0.3s ease, transform 0.2s ease;
        }

        .collapsible:hover {
            background-color: #e9ecef;
        }

        .collapsible .toggle-indicator {
            font-weight: bold;
            font-size: 18px;
            transition: transform 0.2s ease;
        }

        .collapsible.active .toggle-indicator {
            transform: rotate(45deg);
        }

        .hidden {
            display: none;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-5px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>
<h1>PGP-Secure Message</h1>
<div class="container">

    <div class="divider"></div>

    <div class="message-container">
        <div class="section-title">Here is your PGP-secured message:</div>
        <div class="pgp-content" id="message-and-signature">
            <pre>{{ message_signature | e }}</pre>
        </div>
    </div>

    <div class="divider"></div>

    <button class="collapsible" aria-expanded="false" aria-controls="content1">
        Show/Hide just the Message
        <span class="toggle-indicator"> + </span>
    </button>
    <div class="content hidden" id="content1">
        <div class="section-title">The Encrypted Message:</div>
        <div class="pgp-content" id="encrypted-message">
            <pre>{{ message | e }}</pre>
        </div>
    </div>

    <div class="divider"></div>

    <button class="collapsible" aria-expanded="false" aria-controls="content2">
        Show/Hide the Signing Key
        <span class="toggle-indicator"> + </span>
    </button>
    <div class="content hidden" id="content2">
        <div class="section-title">The Server's Public Key:</div>
        <div class="pgp-content" id="server_public_key">
            <pre>{{ server_public_key | e }}</pre>
        </div>
    </div>

    <div class="divider"></div>

    <div class="button-actions">
        <div>
            <button class="button copy-button" onclick="copyToClipboard('message-and-signature')">
                Copy Message and Signature<span class="copy-feedback">Copied!</span>
            </button>
            <button class="button copy-button" onclick="copyToClipboard('encrypted-message')">
                Copy Message<span class="copy-feedback">Copied!</span>
            </button>
            <button class="button copy-button" onclick="copyToClipboard('server_public_key')">
                Copy Server Key<span class="copy-feedback">Copied!</span>
            </button>
        </div>

        <div class="divider"></div>

        <div>
            <a class="button download-button"
               href="data:text/plain;charset=utf-8,{{ message_signature | e('url') }}"
               download="encrypted-message.asc">
                Download the Message Signed .asc
            </a>
            <a class="button download-button"
               href="data:text/plain;charset=utf-8,{{ message | e('url') }}"
               download="message.txt">
                Download the Message as .txt
            </a>
            <a class="button download-button"
               href="data:text/plain;charset=utf-8,{{ server_public_key | e('url') }}"
               download="public-key.asc">
                Download the Public Key .asc
            </a>
        </div>

        <div class="divider"></div>

        <div class="message-container">
            <p>You can verify the signature at the <a href="{{ app_verify_url }}" target="_blank" rel="noopener noreferrer">Verify PGP Page</a>.</p>
        </div>
    </div>
</div>

<script>
	document.addEventListener("DOMContentLoaded", function () {
		const collapsibles = document.querySelectorAll(".collapsible");
		collapsibles.forEach(button => {
			button.addEventListener("click", () => {
				const content = document.getElementById(button.getAttribute('aria-controls'));
				const isHidden = content.classList.toggle("hidden");
				button.setAttribute("aria-expanded", !isHidden);
				button.classList.toggle("active");
			});
		});
	});

	function copyToClipboard(elementId) {
		const content = document.getElementById(elementId);
		if (!content) {
			alert("Element not found.");
			return;
		}
		const textarea = document.createElement("textarea");
		textarea.value = content.textContent.trim();
		document.body.appendChild(textarea);
		textarea.select();
		document.execCommand("copy");
		document.body.removeChild(textarea);
		alert("Copied to clipboard!");
	}
</script>

</body>
</html>
