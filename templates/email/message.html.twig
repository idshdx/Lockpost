<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure PGP Message</title>
</head>
<body style="margin:0;padding:0;background-color:#f8f9fa;font-family:Arial,Helvetica,sans-serif;color:#212529;line-height:1.6;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f8f9fa;padding:24px 0;">
    <tr>
        <td align="center">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:700px;background-color:#ffffff;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.08);overflow:hidden;">

                <!-- Header -->
                <tr>
                    <td style="background-color:#0d6efd;padding:20px 32px;">
                        <p style="margin:0;font-size:20px;font-weight:bold;color:#ffffff;">SYM.PGP.ONY — Secure Message</p>
                        <p style="margin:4px 0 0;font-size:13px;color:#cfe2ff;">You have received a PGP-encrypted message</p>
                    </td>
                </tr>

                <!-- How to use -->
                <tr>
                    <td style="padding:24px 32px 0;">
                        <p style="margin:0 0 8px;font-size:15px;font-weight:bold;color:#212529;">How to use this email</p>
                        <ol style="margin:0;padding-left:20px;font-size:14px;color:#495057;">
                            <li style="margin-bottom:6px;">To <strong>decrypt</strong> your message: copy the <em>Encrypted Message</em> block below and decrypt it with your PGP private key.</li>
                            <li style="margin-bottom:6px;">To <strong>verify</strong> the server's signature you can paste the <em>Signed Message</em> into the <a href="{{ app_verify_url }}" style="color:#0d6efd;">Verify page</a>.</li>
                        </ol>
                        <p style="margin:12px 0 0;font-size:13px;color:#6c757d;">Verification happens entirely in your browser — no data is sent to the server.</p>
                    </td>
                </tr>

                <!-- Divider -->
                <tr><td style="padding:16px 32px;"><hr style="border:none;border-top:1px solid #dee2e6;margin:0;"></td></tr>

                <!-- Section 1: Signed Message (expanded by default) -->
                <tr>
                    <td style="padding:0 32px 16px;">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                                <td>
                                    <button onclick="toggleSection('signed-message','toggle-signed')"
                                            style="width:100%;background-color:#f8f9fa;border:1px solid #dee2e6;border-radius:6px;padding:10px 14px;font-size:14px;font-weight:bold;color:#0d6efd;text-align:left;cursor:pointer;display:flex;justify-content:space-between;align-items:center;"
                                            aria-expanded="true" aria-controls="signed-message">
                                        Signed Message
                                        <span id="toggle-signed" style="font-size:18px;font-weight:bold;transition:transform 0.2s;">−</span>
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td id="signed-message" style="padding-top:8px;">
                                    <p style="margin:0 0 6px;font-size:12px;color:#6c757d;">The full PGP cleartext-signed block — paste this into the Verify page to confirm the server's signature.</p>
                                    <pre id="signed-message-content" style="margin:0;padding:12px;background-color:#f1f3f5;border:1px solid #ced4da;border-radius:4px;font-family:'Courier New',monospace;font-size:12px;white-space:pre-wrap;word-break:break-all;overflow:auto;">{{ message_signature | e }}</pre>
                                    <div style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap;">
                                        <button onclick="copyContent('signed-message-content','copy-fb-signed')"
                                                style="background-color:#0d6efd;border:none;color:#fff;padding:7px 14px;font-size:13px;border-radius:4px;cursor:pointer;">
                                            Copy
                                        </button>
                                        <span id="copy-fb-signed" style="font-size:13px;color:#198754;align-self:center;opacity:0;transition:opacity 0.3s;">Copied!</span>
                                        <a href="data:text/plain;charset=utf-8,{{ message_signature | e('url') }}"
                                           download="signed-message.asc"
                                           style="background-color:#6c757d;color:#fff;padding:7px 14px;font-size:13px;border-radius:4px;text-decoration:none;display:inline-block;">
                                            Download .asc
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- Divider -->
                <tr><td style="padding:0 32px 16px;"><hr style="border:none;border-top:1px solid #dee2e6;margin:0;"></td></tr>

                <!-- Section 2: Encrypted Message (collapsed by default) -->
                <tr>
                    <td style="padding:0 32px 16px;">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                                <td>
                                    <button onclick="toggleSection('encrypted-message','toggle-encrypted')"
                                            style="width:100%;background-color:#f8f9fa;border:1px solid #dee2e6;border-radius:6px;padding:10px 14px;font-size:14px;font-weight:bold;color:#0d6efd;text-align:left;cursor:pointer;display:flex;justify-content:space-between;align-items:center;"
                                            aria-expanded="false" aria-controls="encrypted-message">
                                        Encrypted Message
                                        <span id="toggle-encrypted" style="font-size:18px;font-weight:bold;">+</span>
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td id="encrypted-message" style="display:none;padding-top:8px;">
                                    <p style="margin:0 0 6px;font-size:12px;color:#6c757d;">The raw PGP encrypted block — decrypt this with your PGP private key to read the message.</p>
                                    <pre id="encrypted-message-content" style="margin:0;padding:12px;background-color:#f1f3f5;border:1px solid #ced4da;border-radius:4px;font-family:'Courier New',monospace;font-size:12px;white-space:pre-wrap;word-break:break-all;overflow:auto;">{{ message | e }}</pre>
                                    <div style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap;">
                                        <button onclick="copyContent('encrypted-message-content','copy-fb-encrypted')"
                                                style="background-color:#0d6efd;border:none;color:#fff;padding:7px 14px;font-size:13px;border-radius:4px;cursor:pointer;">
                                            Copy
                                        </button>
                                        <span id="copy-fb-encrypted" style="font-size:13px;color:#198754;align-self:center;opacity:0;transition:opacity 0.3s;">Copied!</span>
                                        <a href="data:text/plain;charset=utf-8,{{ message | e('url') }}"
                                           download="encrypted-message.asc"
                                           style="background-color:#6c757d;color:#fff;padding:7px 14px;font-size:13px;border-radius:4px;text-decoration:none;display:inline-block;">
                                            Download .asc
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- Divider -->
                <tr><td style="padding:0 32px 16px;"><hr style="border:none;border-top:1px solid #dee2e6;margin:0;"></td></tr>

                <!-- Section 3: Server Public Key (collapsed by default) -->
                <tr>
                    <td style="padding:0 32px 24px;">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                                <td>
                                    <button onclick="toggleSection('server-public-key','toggle-pubkey')"
                                            style="width:100%;background-color:#f8f9fa;border:1px solid #dee2e6;border-radius:6px;padding:10px 14px;font-size:14px;font-weight:bold;color:#0d6efd;text-align:left;cursor:pointer;display:flex;justify-content:space-between;align-items:center;"
                                            aria-expanded="false" aria-controls="server-public-key">
                                        Server Public Key
                                        <span id="toggle-pubkey" style="font-size:18px;font-weight:bold;">+</span>
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td id="server-public-key" style="display:none;padding-top:8px;">
                                    <p style="margin:0 0 6px;font-size:12px;color:#6c757d;">The server's public key — used to verify the server's signature.</p>
                                    <pre id="server-public-key-content" style="margin:0;padding:12px;background-color:#f1f3f5;border:1px solid #ced4da;border-radius:4px;font-family:'Courier New',monospace;font-size:12px;white-space:pre-wrap;word-break:break-all;overflow:auto;">{{ server_public_key | e }}</pre>
                                    <div style="margin-top:8px;display:flex;gap:8px;flex-wrap:wrap;">
                                        <button onclick="copyContent('server-public-key-content','copy-fb-pubkey')"
                                                style="background-color:#0d6efd;border:none;color:#fff;padding:7px 14px;font-size:13px;border-radius:4px;cursor:pointer;">
                                            Copy
                                        </button>
                                        <span id="copy-fb-pubkey" style="font-size:13px;color:#198754;align-self:center;opacity:0;transition:opacity 0.3s;">Copied!</span>
                                        <a href="data:text/plain;charset=utf-8,{{ server_public_key | e('url') }}"
                                           download="server-public-key.asc"
                                           style="background-color:#6c757d;color:#fff;padding:7px 14px;font-size:13px;border-radius:4px;text-decoration:none;display:inline-block;">
                                            Download .asc
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- Footer -->
                <tr>
                    <td style="background-color:#f8f9fa;border-top:1px solid #dee2e6;padding:16px 32px;text-align:center;">
                        <p style="margin:0;font-size:13px;color:#6c757d;">
                            Verify the server's signature at the <a href="{{ app_verify_url }}" style="color:#0d6efd;">Verify page</a>.
                        </p>
                    </td>
                </tr>

            </table>
        </td>
    </tr>
</table>

<script>
function toggleSection(sectionId, toggleId) {
    var section = document.getElementById(sectionId);
    var toggle = document.getElementById(toggleId);
    var btn = toggle.parentElement;
    var isHidden = section.style.display === 'none';
    section.style.display = isHidden ? '' : 'none';
    toggle.textContent = isHidden ? '−' : '+';
    btn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
}

function copyContent(elementId, feedbackId) {
    var el = document.getElementById(elementId);
    var fb = document.getElementById(feedbackId);
    if (!el) return;
    var textarea = document.createElement('textarea');
    textarea.value = el.textContent.trim();
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();
    document.execCommand('copy');
    document.body.removeChild(textarea);
    if (fb) {
        fb.style.opacity = '1';
        setTimeout(function() { fb.style.opacity = '0'; }, 2000);
    }
}
</script>

</body>
</html>
