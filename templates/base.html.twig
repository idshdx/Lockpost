<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Lockpost{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔒</text></svg>">
    <link rel="stylesheet" href="{{ asset('bootstrap/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('bootstrap-icons/bootstrap-icons.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body class="d-flex flex-column min-vh-100">
    <a class="visually-hidden-focusable" href="#main-content">Skip to main content</a>

    <nav class="navbar navbar-expand-md bg-body-tertiary" role="navigation" aria-label="Main navigation">
        <div class="container">
            <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">Lockpost</a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarMenu"
                    aria-controls="navbarMenu" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}"
                           {% if app.request.attributes.get('_route') == 'app_home' %}aria-current="page"{% endif %}
                           href="{{ path('app_home') }}">Generate</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_verify' %}active{% endif %}"
                           {% if app.request.attributes.get('_route') == 'app_verify' %}aria-current="page"{% endif %}
                           href="{{ path('app_verify') }}">Verify</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'app_about' %}active{% endif %}"
                           {% if app.request.attributes.get('_route') == 'app_about' %}aria-current="page"{% endif %}
                           href="{{ path('app_about') }}">About</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main id="main-content" class="container py-4">
        {% block flash_messages %}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show"
                         role="alert">
                        {{ message|nl2br }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Dismiss alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        {% endblock %}
        {% block body %}{% endblock %}
    </main>

    <footer class="py-4 mt-auto border-top" role="contentinfo">
        <div class="container d-flex flex-wrap justify-content-between align-items-center">
            <span class="text-body-secondary">
                Lockpost — Share a link. Receive a secret. Leave no trace.
            </span>
            <ul class="nav">
                <li class="nav-item"><a class="nav-link text-body-secondary" href="https://github.com/idshdx/sym-pgp-ony">Source code</a></li>
                <li class="nav-item"><a class="nav-link text-body-secondary" href="{{ path('app_privacy') }}">Privacy policy</a></li>
            </ul>
        </div>
    </footer>

    <script src="{{ asset('bootstrap/bootstrap.min.js') }}"></script>
    {{ importmap('app') }}
    {% block javascripts %}{% endblock %}
</body>
</html>
