{% extends 'base.html.twig' %}

{% block title %}Submit Encrypted Message — SYM.PGP.ONY{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h1 class="mb-4" id="page-heading">Send Encrypted Message</h1>

            <div class="alert alert-info mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <h2 class="h6 mb-0" id="how-it-works-heading">How it works</h2>
                    <button class="btn btn-sm btn-outline-secondary" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#submit-how-it-works"
                            aria-expanded="false"
                            aria-controls="submit-how-it-works">
                        Show / Hide
                    </button>
                </div>
                <div class="collapse" id="submit-how-it-works">
                    <ul class="mt-2 mb-0">
                        <li>Your message is encrypted in your browser using the recipient's PGP key before it leaves your device.</li>
                        <li>The application signs the encrypted message and forwards it to the mailbox that shared this link with you.</li>
                        <li>JavaScript and a modern browser are required for client-side encryption.</li>
                        <li>The original message is never stored or transmitted unencrypted.</li>
                    </ul>
                </div>
            </div>

            <noscript>
                <div class="alert alert-danger mb-4" role="alert">
                    <strong>JavaScript is required.</strong>
                    This page uses client-side encryption to protect your message before it leaves your browser.
                    It cannot function without JavaScript. Please enable JavaScript in your browser settings and reload the page.
                </div>
            </noscript>

            <form id="messageForm"
                  aria-labelledby="page-heading"
                  data-controller="submit"
                  data-action="submit->submit#submit"
                  data-submit-recipient-value="{{ email }}"
                  data-submit-public-key-value="{{ publicKey|e('html_attr') }}"
                  data-submit-submit-url-value="{{ path('app_submit_message') }}"
                  data-submit-home-url-value="{{ path('app_home') }}">

                <div class="mb-3">
                    <label for="message" class="form-label">Your Message</label>
                    <textarea class="form-control" id="message" rows="6" required
                              data-submit-target="message"></textarea>
                </div>

                <div class="d-none" data-submit-target="feedback" role="alert"></div>

                <div class="d-none" data-submit-target="loading">
                    <div class="alert alert-warning">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        Encrypting and sending&hellip;
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" data-submit-target="submitBtn">
                    Send
                </button>
            </form>
        </div>
    </div>
{% endblock %}
