{% extends 'base.html.twig' %}

{% block title %}Generate Secure Message Link — SYM.PGP.ONY{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h1 class="mb-4" id="page-heading">Generate Secure Message Link</h1>

            <section aria-labelledby="how-it-works-heading" class="alert alert-info mb-4">
                <h2 id="how-it-works-heading" class="h5">How it works</h2>
                <ol class="mb-0">
                    <li>Enter your email address that has a public PGP key published on key servers.</li>
                    <li>Receive a shareable link you can send to anyone who needs to contact you securely.</li>
                    <li>When the recipient opens the link, their message is encrypted client-side in their browser before it ever leaves their device.</li>
                    <li>You receive the encrypted message in your email inbox and decrypt it with your private PGP key.</li>
                </ol>
            </section>

            {{ form_start(form, {'attr': {'aria-labelledby': 'page-heading', 'novalidate': 'novalidate'}}) }}
            {{ form_errors(form) }}
            {{ form_widget(form) }}
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
